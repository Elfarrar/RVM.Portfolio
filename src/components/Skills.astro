---
import { tr, type Locale } from "../data/i18n";
interface Props { lang: Locale; }
const { lang } = Astro.props;

const groups = [
  {
    label: lang === "pt" ? "linguagens & frameworks" : "languages & frameworks",
    items: ["C# / .NET 10", "ASP.NET Core", "Blazor Server", "Entity Framework", "TypeScript", "JavaScript"],
  },
  {
    label: lang === "pt" ? "dados & integracao" : "data & integration",
    items: ["PostgreSQL", "SQL Server", "Redis", "Dapper", "REST APIs", "OpenIddict"],
  },
  {
    label: lang === "pt" ? "infra & devops" : "infra & devops",
    items: ["Docker", "Nginx", "GitHub Actions", "Linux / SSH", "Lets Encrypt", "Cloudflare"],
  },
  {
    label: lang === "pt" ? "frontend moderno" : "modern frontend",
    items: ["Astro", "Tailwind CSS", "Motion", "View Transitions", "Playwright", "OpenAPI"],
  },
];
---

<section id="skills" class="skills">
  <header class="skills-header reveal">
    <span class="tag mono">/ {tr(lang, "nav.skills").toLowerCase()}</span>
    <h2 class="skills-title display">
      {lang === "pt" ? "Stack viva." : "Living stack."}<br/>
      <span class="mix-italic">{lang === "pt" ? "Em producao." : "In production."}</span>
    </h2>
  </header>

  <div class="skills-grid">
    {groups.map((g) => (
      <div class="skills-group reveal">
        <h4 class="skills-label mono">/ {g.label}</h4>
        <ul class="skills-list">
          {g.items.map((it) => (
            <li class="skills-item">
              <span class="skills-bullet" aria-hidden="true"></span>
              <span>{it}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
  .skills {
    max-width: 1200px;
    margin: 8rem auto 0;
    padding: 0 1.5rem;
  }

  .skills-header { max-width: 720px; margin-bottom: 3rem; }

  .skills-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.0;
    margin: 1.25rem 0 0;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.5rem 1.5rem;
    padding: 2.5rem;
    border-radius: 20px;
    border: 1px solid var(--color-border);
    background: oklch(14% 0.01 270 / 0.5);
    backdrop-filter: blur(16px);
  }

  .skills-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .skills-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .skills-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    color: var(--color-text);
    font-size: 0.9375rem;
    transition: transform 0.4s var(--ease-out-expo), color 0.3s ease;
  }

  .skills-bullet {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.5;
    transition: opacity 0.3s, transform 0.3s;
  }

  .skills-item:hover {
    color: var(--color-accent);
    transform: translateX(4px);
  }
  .skills-item:hover .skills-bullet {
    opacity: 1;
    transform: scale(1.5);
  }

  @media (max-width: 900px) { .skills-grid { grid-template-columns: repeat(2, 1fr); padding: 1.75rem; } }
  @media (max-width: 480px) { .skills-grid { grid-template-columns: 1fr; } }
</style>
