---
/**
 * AuroraOrbs — orbs gradient flutuando no fundo, com hue rotation lento.
 * Posicionados absolutos. Animados via parallax no script Motion.
 */
---

<div class="aurora" aria-hidden="true">
  <div class="orb orb-1" data-orb data-orb-speed="0.3"></div>
  <div class="orb orb-2" data-orb data-orb-speed="0.18"></div>
  <div class="orb orb-3" data-orb data-orb-speed="0.45"></div>
</div>

<style>
  .aurora {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.55;
    will-change: transform;
    animation: float 20s ease-in-out infinite, hue-rotate 30s linear infinite;
  }

  .orb-1 {
    width: 520px;
    height: 520px;
    top: -80px;
    left: -120px;
    background: radial-gradient(circle, oklch(72% 0.22 250 / 0.35), transparent 70%);
  }

  .orb-2 {
    width: 460px;
    height: 460px;
    bottom: -100px;
    right: -80px;
    background: radial-gradient(circle, oklch(70% 0.18 280 / 0.28), transparent 70%);
    animation-delay: -7s;
  }

  .orb-3 {
    width: 380px;
    height: 380px;
    top: 50%;
    left: 60%;
    background: radial-gradient(circle, oklch(75% 0.15 50 / 0.18), transparent 70%);
    animation-delay: -14s;
  }

  @media (max-width: 768px) {
    .orb { filter: blur(60px); opacity: 0.4; }
    .orb-1 { width: 320px; height: 320px; }
    .orb-2 { width: 280px; height: 280px; }
    .orb-3 { display: none; }
  }
</style>
