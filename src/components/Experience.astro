---
import { tr, type Locale } from "../data/i18n";
interface Props { lang: Locale; }
const { lang } = Astro.props;

const entries = lang === "pt" ? [
  {
    period: "2018 — atual",
    role: "Senior Software Engineer",
    company: "Questrade",
    location: "Toronto · remoto",
    body: "Aplicacoes bancarias, APIs RESTful, processamento de dados com SQL Server. Automacao de deploys com Jenkins, Docker e Git.",
  },
  {
    period: "2014 — 2018",
    role: "Pleno / Senior",
    company: "Diversos clientes",
    location: "Belo Horizonte",
    body: "ERPs com arquitetura DDD, plataformas de gestao de pessoas com Angular e ASP.NET. Modernizacao de legados.",
  },
  {
    period: "2009 — 2014",
    role: "Junior / Pleno",
    company: "Inicio de carreira",
    location: "Brasil",
    body: "Primeiros sistemas em ASP.NET Web Forms e MVC. SQL Server, jQuery, integracoes corporativas.",
  },
] : [
  {
    period: "2018 — present",
    role: "Senior Software Engineer",
    company: "Questrade",
    location: "Toronto · remote",
    body: "Banking applications, RESTful APIs, data processing with SQL Server. Deploy automation with Jenkins, Docker and Git.",
  },
  {
    period: "2014 — 2018",
    role: "Mid / Senior",
    company: "Various clients",
    location: "Belo Horizonte",
    body: "ERPs with DDD architecture, people management platforms with Angular and ASP.NET. Legacy modernization.",
  },
  {
    period: "2009 — 2014",
    role: "Junior / Mid",
    company: "Career start",
    location: "Brazil",
    body: "First systems in ASP.NET Web Forms and MVC. SQL Server, jQuery, corporate integrations.",
  },
];
---

<section id="experience" class="exp">
  <header class="exp-header reveal">
    <span class="tag mono">/ {tr(lang, "nav.experience").toLowerCase()}</span>
    <h2 class="exp-title display">
      {lang === "pt" ? "Quase 17 anos" : "Almost 17 years"}<br/>
      <span class="mix-italic">{lang === "pt" ? "no mesmo stack." : "on the same stack."}</span>
    </h2>
  </header>

  <ol class="exp-list">
    {entries.map((e) => (
      <li class="exp-item reveal">
        <div class="exp-period mono">{e.period}</div>
        <div class="exp-content">
          <h3 class="exp-role">{e.role}</h3>
          <div class="exp-company">{e.company} · <span class="mono">{e.location}</span></div>
          <p class="exp-body">{e.body}</p>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .exp {
    max-width: 1200px;
    margin: 8rem auto 0;
    padding: 0 1.5rem;
  }

  .exp-header { max-width: 720px; margin-bottom: 3rem; }

  .exp-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.0;
    margin: 1.25rem 0 0;
  }

  .exp-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 1px solid var(--color-border);
    padding-left: 0;
  }

  .exp-item {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 2rem;
    padding: 2rem 0 2rem 2rem;
    position: relative;
    border-left: 1px solid var(--color-border);
    margin-left: 0;
  }

  .exp-item::before {
    content: "";
    position: absolute;
    left: -5px;
    top: 2.25rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 12px var(--color-accent);
  }

  .exp-period {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--color-accent);
    text-transform: uppercase;
    padding-top: 0.25rem;
  }

  .exp-role {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    margin: 0 0 0.25rem;
  }

  .exp-company {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    margin-bottom: 0.875rem;
  }

  .exp-company .mono {
    font-size: 0.8125rem;
    color: var(--color-text-subtle);
  }

  .exp-body {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .exp-item { grid-template-columns: 1fr; gap: 0.5rem; }
  }
</style>
