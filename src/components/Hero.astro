---
import { tr, type Locale } from "../data/i18n";
interface Props { lang: Locale; }
const { lang } = Astro.props;
const isPt = lang === "pt";
---

<section class="hero">
  <div class="hero-grid">
    <div class="hero-copy">
      <span class="tag tag-dot">{tr(lang, "hero.label")}</span>

      <h1 class="hero-title">
        <span data-split>Rafael</span>
        <br/>
        <span class="mix-italic" data-split>{isPt ? "Veneroso Morici." : "Veneroso Morici."}</span>
      </h1>

      <p class="hero-role mono">
        {isPt ? "/ engenheiro de software / .NET / 15+ anos" : "/ senior software engineer / .NET / 15+ years"}
      </p>

      <p class="hero-sub">{tr(lang, "hero.desc")}</p>

      <div class="hero-cta">
        <a href={`${isPt ? "" : "/en"}/#projects`} class="btn btn-primary" data-magnetic>
          <span>{tr(lang, "hero.btn.projects")}</span>
        </a>
        <a href="https://github.com/Elfarrar" target="_blank" rel="noopener" class="btn btn-ghost" data-magnetic data-magnetic-strength="0.25">
          <span>GitHub &nearr;</span>
        </a>
        <a href="https://linkedin.com/in/rafael-veneroso-morici" target="_blank" rel="noopener" class="btn btn-ghost" data-magnetic data-magnetic-strength="0.25">
          <span>LinkedIn &nearr;</span>
        </a>
      </div>

      <div class="hero-meta">
        <div class="meta-item">
          <span class="meta-num display">15+</span>
          <span class="meta-label mono">{isPt ? "anos em .NET" : "years on .NET"}</span>
        </div>
        <div class="meta-divider"></div>
        <div class="meta-item">
          <span class="meta-num display">11</span>
          <span class="meta-label mono">{isPt ? "projetos open" : "open projects"}</span>
        </div>
        <div class="meta-divider"></div>
        <div class="meta-item">
          <span class="meta-num display">100%</span>
          <span class="meta-label mono">{isPt ? "remoto" : "remote"}</span>
        </div>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="card card-1">
        <span class="card-num mono">/01</span>
        <div class="card-title display">.NET Core</div>
        <div class="card-tag mono">backend</div>
      </div>
      <div class="card card-2">
        <span class="card-num mono">/02</span>
        <div class="card-title display">Postgres</div>
        <div class="card-tag mono">data</div>
      </div>
      <div class="card card-3">
        <span class="card-num mono">/03</span>
        <div class="card-title display">Blazor</div>
        <div class="card-tag mono">ui</div>
      </div>
      <div class="card card-4">
        <span class="card-num mono">/04</span>
        <div class="card-title display">Docker</div>
        <div class="card-tag mono">infra</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    padding: 8rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  .hero-grid {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-copy { max-width: 640px; }

  .hero-title {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    line-height: 1.0;
    letter-spacing: var(--tracking-display);
    color: var(--color-text);
  }

  .hero-role {
    color: var(--color-accent);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    margin-bottom: 1.75rem;
  }

  .hero-sub {
    font-size: clamp(1rem, 1.5vw, 1.0625rem);
    color: var(--color-text-muted);
    max-width: 560px;
    margin-bottom: 2.5rem;
    line-height: 1.65;
  }

  .hero-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .meta-item { display: flex; flex-direction: column; gap: 0.25rem; }
  .meta-num { font-size: 1.875rem; line-height: 1; color: var(--color-accent); }
  .meta-label {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }
  .meta-divider {
    width: 1px;
    height: 28px;
    background: var(--color-border);
  }

  /* Visual: floating tech cards */
  .hero-visual {
    position: relative;
    aspect-ratio: 1 / 1;
    width: 100%;
    max-width: 480px;
    min-height: 460px;
    margin-left: auto;
  }

  .card {
    position: absolute;
    width: 180px;
    padding: 1.25rem;
    border-radius: 14px;
    background: oklch(13% 0.005 270 / 0.85);
    border: 1px solid var(--color-border-strong);
    backdrop-filter: blur(12px);
    box-shadow: 0 30px 60px oklch(0% 0 0 / 0.5);
    animation: float 8s ease-in-out infinite;
  }

  .card-num {
    font-size: 0.6875rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }

  .card-title {
    font-size: 1.5rem;
    margin: 0.5rem 0 0.25rem;
    font-weight: 600;
  }

  .card-tag {
    font-size: 0.6875rem;
    color: var(--color-text-subtle);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card-1 { top: 6%;  left: 12%; transform: rotate(-6deg); animation-delay: 0s; }
  .card-2 { top: 14%; right: 4%; transform: rotate(4deg);  animation-delay: -2s; }
  .card-3 { bottom: 18%; left: 4%; transform: rotate(3deg); animation-delay: -4s; }
  .card-4 { bottom: 6%; right: 8%; transform: rotate(-4deg); animation-delay: -6s; }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3rem; }
    .hero-visual { max-width: 360px; margin: 0 auto; min-height: 360px; }
    .card { width: 150px; padding: 1rem; }
  }
</style>
